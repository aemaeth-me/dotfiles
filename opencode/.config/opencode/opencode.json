{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {},
  "provider": {
    "deepseek": {
      "api": "openai-compatible",
      "name": "DeepSeek",
      "options": {
        "apiKey": "{env:DEEPSEEK_API_KEY}",
        "baseURL": "https://api.deepseek.com"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 384000
          },
          "cost": {
            "input": 1,
            "output": 2,
            "cache_read": 0.2
          },
          "variants": {
            "none": {
              "thinking": { "type": "disabled" }
            },
            "minimal": {
              "thinking": { "type": "disabled" }
            },
            "low": {
              "thinking": { "type": "enabled" },
              "reasoning_effort": "high"
            },
            "medium": {
              "thinking": { "type": "enabled" },
              "reasoning_effort": "high"
            },
            "high": {
              "thinking": { "type": "enabled" },
              "reasoning_effort": "high"
            },
            "xhigh": {
              "thinking": { "type": "enabled" },
              "reasoning_effort": "max"
            }
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 384000
          },
          "cost": {
            "input": 12,
            "output": 24,
            "cache_read": 1
          },
          "variants": {
            "none": {
              "thinking": { "type": "disabled" }
            },
            "minimal": {
              "thinking": { "type": "disabled" }
            },
            "low": {
              "thinking": { "type": "enabled" },
              "reasoning_effort": "high"
            },
            "medium": {
              "thinking": { "type": "enabled" },
              "reasoning_effort": "high"
            },
            "high": {
              "thinking": { "type": "enabled" },
              "reasoning_effort": "high"
            },
            "xhigh": {
              "thinking": { "type": "enabled" },
              "reasoning_effort": "max"
            }
          }
        }
      }
    }
  },
  "model": "deepseek/deepseek-v4-pro",
  "mcp": {
    "brave": {
      "type": "local",
      "command": ["npx", "-y", "@brave/brave-search-mcp-server"],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      },
      "enabled": true
    }
  }
}
